generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// ISO-style locale codes supported in the app. Add new variants via migration when you add languages.
enum AppLocale {
  en
  fr
}

enum OAuthProvider {
  GOOGLE
  APPLE
  FACEBOOK
}

model User {
  id                String     @id @default(uuid())
  /// Nullable for OAuth-only accounts; unique when set (multiple NULLs allowed in PostgreSQL).
  email             String?    @unique
  /// Null when the user only signs in via OAuth.
  passwordHash      String?
  name              String?
  avatarUrl         String?
  preferredLanguage AppLocale  @default(en)
  favoriteTopics    String[]   @default([])
  dailyDigest       Boolean    @default(false)
  breakingNews      Boolean    @default(false)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  savedArticles   SavedArticle[]
  readingHistory  ReadingHistory[]
  oauthAccounts   OAuthAccount[]

  @@map("users")
}

model OAuthAccount {
  id             String        @id @default(uuid())
  provider       OAuthProvider
  providerUserId String
  userId         String
  createdAt      DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("oauth_accounts")
}

/// Ephemeral session for guest bookmarks / reading history before signup (bonus merge on register).
model GuestSession {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  expiresAt DateTime?

  savedArticles  GuestSavedArticle[]
  readingHistory GuestReadingHistory[]

  @@index([createdAt])
  @@map("guest_sessions")
}

model GuestSavedArticle {
  id             String   @id @default(uuid())
  guestSessionId String
  articleId      String
  savedAt        DateTime @default(now())

  session GuestSession @relation(fields: [guestSessionId], references: [id], onDelete: Cascade)
  article Article      @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([guestSessionId, articleId])
  @@index([guestSessionId])
  @@map("guest_saved_articles")
}

model GuestReadingHistory {
  id             String   @id @default(uuid())
  guestSessionId String
  articleId      String
  readAt         DateTime @default(now())

  session GuestSession @relation(fields: [guestSessionId], references: [id], onDelete: Cascade)
  article Article      @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([guestSessionId, articleId])
  @@index([guestSessionId])
  @@map("guest_reading_history")
}

model SavedArticle {
  id        String   @id @default(uuid())
  userId    String
  articleId String
  savedAt   DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@index([userId])
  @@map("saved_articles")
}

model ReadingHistory {
  id        String   @id @default(uuid())
  userId    String
  articleId String
  readAt    DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@index([userId])
  @@map("reading_history")
}

model Article {
  id               String   @id @default(uuid())
  title            String
  content          String   @db.Text
  summary          String?  @db.Text
  summaryFr        String?  @db.Text
  originalLanguage String   @default("en")
  source           String
  url              String   @unique
  category         String?
  continent        String?
  region           String?
  country          String?
  publishedAt      DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  savedBy             SavedArticle[]
  readingHistory      ReadingHistory[]
  guestSaves          GuestSavedArticle[]
  guestReadingHistory GuestReadingHistory[]

  @@index([category])
  @@index([country])
  @@index([continent])
  @@index([publishedAt])
  @@index([originalLanguage])
  @@map("articles")
}
