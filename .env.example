# Application
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/news_summarizer?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TTL=1800

# Google AI (Gemini) — primary summarizer
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Groq AI — fallback summarizer (used when Gemini fails)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Auth (email/password + JWT for your own clients)
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d

# Social sign-in (ID token / access token from mobile or web SDKs, verified on the server)
# Google: OAuth 2.0 Client IDs (Web, iOS, Android) from Google Cloud Console
GOOGLE_CLIENT_IDS=your-web-client-id.apps.googleusercontent.com,your-ios-client-id.apps.googleusercontent.com

# Apple: Service ID and/or iOS bundle id (values that appear as `aud` in the Apple ID token)
APPLE_CLIENT_IDS=com.yourcompany.app,com.yourcompany.app.service

# Facebook: used to validate the user access token (Graph API debug_token)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Review Details — attach model name, per-step timing, and provider attempt info to summarization results
REVIEW_DETAILS_ENABLED=false
