# Application
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/news_summarizer?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TTL=1800

# Google AI (Gemini) — fallback summarizer
GEMINI_API_KEY=your_gemini_api_key_here
# Override the default model if you have access to a different tier
# GEMINI_MODEL=gemini-2.0-flash

# Groq AI — primary summarizer
GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.1-8b-instant

# HTTP rate limiting (express → @nestjs/throttler)
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# LLM provider rate limits — keep these UNDER your plan's published ceilings.
# Free tiers (verified Apr 2026):
#   Groq llama-3.1-8b-instant: 30 RPM / 6000 TPM / 14400 RPD
#   Gemini gemini-2.0-flash:   15 RPM / ~1M TPM / 1500 RPD
GROQ_RPM=25
GROQ_TPM=5500
GEMINI_RPM=12
GEMINI_TPM=800000

# BullMQ summarization worker tuning
SUMMARIZATION_CONCURRENCY=2
SUMMARIZATION_ATTEMPTS=5
SUMMARIZATION_BACKOFF_MS=4000

# Optional Redis auth
# REDIS_PASSWORD=
# REDIS_DB=0

# JWT — issued by this server after Firebase ID token verification
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d

# Admin — required header X-Admin-Key for POST /articles/ingest, resummarize, backfill-french
ADMIN_API_KEY=generate_a_long_random_secret

# Firebase Admin SDK
# Your Firebase project ID (Firebase Console > Project Settings > General)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Option A — Service account JSON as a single-line string (recommended for containers / CI)
# Generate: Firebase Console > Project Settings > Service Accounts > Generate new private key
# Paste the entire JSON content collapsed to one line:
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"..."}

# Option B — Path to a service account JSON file (local development)
# Download the JSON and point to it with the standard Google env var:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/serviceAccountKey.json

# Review Details (internal feature flag)
REVIEW_DETAILS_ENABLED=false
