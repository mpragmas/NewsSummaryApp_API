# Application
NODE_ENV=development
PORT=3000
# Listen on all interfaces so phones on Wi‑Fi can reach the API (default is already 0.0.0.0)
# HOST=0.0.0.0

# CORS — restrict to your frontend origin in production (leave blank for * in dev)
# CORS_ORIGIN=https://your-frontend-domain.com

# Swagger UI — set to true to enable in production (always on in development)
# SWAGGER_ENABLED=false

# Database (PostgreSQL) — Neon/Supabase: add ?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/news_summarizer?schema=public"

# Redis — cloud (Upstash): set REDIS_URL only (copy from dashboard → Redis tab, NOT redis-cli)
REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_ENDPOINT.upstash.io:6379
REDIS_TTL=1800
# Local Docker Redis (only if REDIS_URL is unset):
# REDIS_HOST=localhost
# REDIS_PORT=6379

# Google AI (Gemini) — fallback summarizer
GEMINI_API_KEY=your_gemini_api_key_here
# Override the default model if you have access to a different tier
# GEMINI_MODEL=gemini-2.0-flash

# Groq AI — primary summarizer
GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.1-8b-instant

# HTTP rate limiting (express → @nestjs/throttler)
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# LLM provider rate limits — keep these UNDER your plan's published ceilings.
# Free tiers (verified Apr 2026):
#   Groq llama-3.1-8b-instant: 30 RPM / 6000 TPM / 14400 RPD
#   Gemini gemini-2.0-flash:   15 RPM / ~1M TPM / 1500 RPD
GROQ_RPM=25
GROQ_TPM=5500
GEMINI_RPM=12
GEMINI_TPM=800000

# BullMQ summarization worker tuning
SUMMARIZATION_CONCURRENCY=2
SUMMARIZATION_ATTEMPTS=5
SUMMARIZATION_BACKOFF_MS=4000

# Optional Redis auth
# REDIS_PASSWORD=
# REDIS_DB=0

# JWT — issued by this server after OAuth token verification
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d

# Admin — required header X-Admin-Key for POST /articles/ingest, resummarize, backfill-french
ADMIN_API_KEY=generate_a_long_random_secret

# OAuth (Google only, comma-separated for multiple client IDs)
OAUTH_GOOGLE_CLIENT_IDS=your-google-web-client-id.apps.googleusercontent.com

# Review Details (internal feature flag)
REVIEW_DETAILS_ENABLED=false
