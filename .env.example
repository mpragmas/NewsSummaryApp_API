# Application
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/news_summarizer?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TTL=1800

# Google AI (Gemini) — primary summarizer
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Groq AI — fallback summarizer (used when Gemini fails)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100
