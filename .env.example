# Application
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/news_summarizer?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TTL=1800

# Google AI (Gemini) — primary summarizer
GEMINI_API_KEY=your_gemini_api_key_here

# Groq AI — fallback summarizer
GROQ_API_KEY=your_groq_api_key_here

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# JWT — issued by this server after Firebase ID token verification
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d

# Admin — required header X-Admin-Key for POST /articles/ingest, resummarize, backfill-french
ADMIN_API_KEY=generate_a_long_random_secret

# Firebase Admin SDK
# Your Firebase project ID (Firebase Console > Project Settings > General)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Option A — Service account JSON as a single-line string (recommended for containers / CI)
# Generate: Firebase Console > Project Settings > Service Accounts > Generate new private key
# Paste the entire JSON content collapsed to one line:
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"..."}

# Option B — Path to a service account JSON file (local development)
# Download the JSON and point to it with the standard Google env var:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/serviceAccountKey.json

# Review Details (internal feature flag)
REVIEW_DETAILS_ENABLED=false
